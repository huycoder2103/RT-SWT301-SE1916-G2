    // deleteConstraint

    // SCENARIO op=deleteConstraint type=positive expect=2xx
    @Test
    void deleteConstraint_P_existingConstraint() {
        given().when().post("/products/TestProduct_ConstDel").then();
        given().when().post("/products/TestProduct_ConstDel/features/FeatureCDA").then();
        given().when().post("/products/TestProduct_ConstDel/features/FeatureCDB").then();
        given()
            .formParam("sourceFeature", "FeatureCDA")
            .formParam("requiredFeature", "FeatureCDB")
            .when().post("/products/TestProduct_ConstDel/constraints/requires").then();

        io.restassured.response.Response resp = given()
            .when().get("/products/TestProduct_ConstDel")
            .then().statusCode(200).extract().response();

        long constraintId = resp.jsonPath().getLong("constraints[0].id");

        given()
            .when().delete("/products/TestProduct_ConstDel/constraints/" + constraintId)
            .then().statusCode(anyOf(is(200), is(204)));
    }


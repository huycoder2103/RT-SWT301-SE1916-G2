    // SCENARIO op=deleteConstraint type=errorcode expect=error
    @Test
    void deleteConstraint_E_doubleDelete() {
        given().when().post("/products/TestProduct_ConstDD").then();
        given().when().post("/products/TestProduct_ConstDD/features/FeatureDDA").then();
        given().when().post("/products/TestProduct_ConstDD/features/FeatureDDB").then();
        given()
            .formParam("sourceFeature", "FeatureDDA")
            .formParam("requiredFeature", "FeatureDDB")
            .when().post("/products/TestProduct_ConstDD/constraints/requires").then();

        io.restassured.response.Response resp = given()
            .when().get("/products/TestProduct_ConstDD")
            .then().statusCode(200).extract().response();

        long constraintId = resp.jsonPath().getLong("constraints[0].id");

        given().when().delete("/products/TestProduct_ConstDD/constraints/" + constraintId).then();

        given()
            .when().delete("/products/TestProduct_ConstDD/constraints/" + constraintId)
            .then().statusCode(anyOf(is(400), is(404), is(422), is(500)));
    }
}

package manual;

import org.junit.jupiter.api.BeforeAll;
import org.junit.jupiter.api.Test;
import io.restassured.RestAssured;
import static io.restassured.RestAssured.given;
import static org.hamcrest.Matchers.*;

public class FeaturesManualTests {

    @BeforeAll
    static void setup() {
        RestAssured.baseURI = System.getProperty("baseURI", "http://localhost:8080");
        RestAssured.urlEncodingEnabled = true;
        RestAssured.enableLoggingOfRequestAndResponseIfValidationFails();
    }

    // getAllProducts

    // SCENARIO op=getAllProducts type=positive expect=200
    @Test
    void getAllProducts_P_returnsArray() {
        given()
            .when().get("/products")
            .then().statusCode(200)
            .body("$", instanceOf(java.util.List.class));
    }

    // addProduct / getProductByName / deleteProductByName  (lifecycle)

    // SCENARIO op=addProduct type=positive expect=2xx
    @Test
    void addProduct_P_createNewProduct() {
        given()
            .when().post("/products/TestProduct_AddP")
            .then().statusCode(anyOf(is(200), is(201), is(204)));
    }

    // SCENARIO op=getProductByName type=positive expect=200
    @Test
    void getProductByName_P_existingProduct() {
        given().when().post("/products/TestProduct_GetP").then();

        given()
            .when().get("/products/TestProduct_GetP")
            .then().statusCode(200)
            .body("name", equalTo("TestProduct_GetP"));
    }

    // SCENARIO op=getProductByName type=negative expect=error
    @Test
    void getProductByName_N_nonExistentProduct() {
        given()
            .when().get("/products/NoSuchProduct_xyzzy_99999")
            .then().statusCode(anyOf(is(400), is(404), is(422), is(500)));
    }

    // SCENARIO op=getProductByName type=boundary expect=200
    @Test
    void getProductByName_B_singleCharName() {
        given().when().post("/products/X").then();

        given()
            .when().get("/products/X")
            .then().statusCode(anyOf(is(200), is(400), is(404)));
    }

    // SCENARIO op=getProductByName type=boundary expect=200-or-error
    @Test
    void getProductByName_B_longProductName() {
        String longName = "A".repeat(255);
        given().when().post("/products/" + longName).then();

        given()
            .when().get("/products/" + longName)
            .then().statusCode(anyOf(is(200), is(400), is(404), is(414), is(422), is(500)));
    }

    // SCENARIO op=deleteProductByName type=positive expect=2xx
    @Test
    void deleteProductByName_P_existingProduct() {
        given().when().post("/products/TestProduct_DelP").then();

        given()
            .when().delete("/products/TestProduct_DelP")
            .then().statusCode(anyOf(is(200), is(204)));
    }

    // SCENARIO op=deleteProductByName type=negative expect=error

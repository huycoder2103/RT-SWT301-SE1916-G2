package manual;

import org.junit.jupiter.api.BeforeAll;
import org.junit.jupiter.api.Test;
import io.restassured.RestAssured;
import static io.restassured.RestAssured.given;
import static org.hamcrest.Matchers.*;

public class NcsManualTests {

    @BeforeAll
    static void setup() {
        RestAssured.baseURI = System.getProperty("baseURI", "http://localhost:8080");
        RestAssured.urlEncodingEnabled = true;
    }

    // /api/bessj/{n}/{x}  — Bessel function J_n(x)

    // SCENARIO op=bessjUsingGET type=positive expect=200
    @Test
    void bessjUsingGET_P_typicalPositiveNX() {
        given()
            .when().get("/api/bessj/2/1.5")
            .then().statusCode(200)
            .body("resultAsDouble", notNullValue());
    }

    // SCENARIO op=bessjUsingGET type=positive expect=200
    @Test
    void bessjUsingGET_P_nEquals1XPositive() {
        given()
            .when().get("/api/bessj/1/3.0")
            .then().statusCode(200)
            .body("resultAsDouble", notNullValue());
    }

    // SCENARIO op=bessjUsingGET type=boundary expect=200
    @Test
    void bessjUsingGET_B_nZero() {
        given()
            .when().get("/api/bessj/0/1.0")
            .then().statusCode(200)
            .body("resultAsDouble", notNullValue());
    }

    // SCENARIO op=bessjUsingGET type=boundary expect=200
    @Test
    void bessjUsingGET_B_xZero() {
        given()
            .when().get("/api/bessj/2/0.0")
            .then().statusCode(200)
            .body("resultAsDouble", notNullValue());
    }

    // SCENARIO op=bessjUsingGET type=boundary expect=200
    @Test
    void bessjUsingGET_B_nNegative() {
        given()
            .when().get("/api/bessj/-1/1.0")
            .then().statusCode(anyOf(is(200), is(400), is(422)));
    }

    // SCENARIO op=bessjUsingGET type=boundary expect=200
    @Test
    void bessjUsingGET_B_xNegative() {
        given()
            .when().get("/api/bessj/2/-1.0")
            .then().statusCode(anyOf(is(200), is(400), is(422)));
    }

    // SCENARIO op=bessjUsingGET type=negative expect=error-class
    @Test
    void bessjUsingGET_N_nIsString() {
        given()
            .when().get("/api/bessj/abc/1.0")
            .then().statusCode(anyOf(is(400), is(404), is(422), is(500)));
    }

    // SCENARIO op=bessjUsingGET type=negative expect=error-class
    @Test
    void bessjUsingGET_N_xIsString() {
        given()
            .when().get("/api/bessj/2/xyz")
            .then().statusCode(anyOf(is(400), is(404), is(422), is(500)));
    }

    // SCENARIO op=bessjUsingGET type=errorcode expect=error-class
    @Test
    void bessjUsingGET_E_missingXSegment() {
        given()
            .when().get("/api/bessj/2")
            .then().statusCode(anyOf(is(400), is(404), is(422), is(500)));
    }

    // SCENARIO op=bessjUsingGET type=errorcode expect=error-class
    @Test
    void bessjUsingGET_E_emptyNSegment() {
        given()
            .when().get("/api/bessj//1.0")
            .then().statusCode(anyOf(is(400), is(404), is(422), is(500)));
    }


    // /api/remainder/{a}/{b}  — Integer remainder a % b

    // SCENARIO op=remainderUsingGET type=positive expect=200
    @Test
    void remainderUsingGET_P_typicalPositiveAB() {
        given()
            .when().get("/api/remainder/10/3")
            .then().statusCode(200)
            .body("resultAsInt", notNullValue());
    }

    // SCENARIO op=remainderUsingGET type=positive expect=200
    @Test
    void remainderUsingGET_P_aLessThanB() {
        given()
            .when().get("/api/remainder/3/10")
            .then().statusCode(200)
            .body("resultAsInt", is(3));
    }

    // SCENARIO op=remainderUsingGET type=positive expect=200
    @Test
    void remainderUsingGET_P_aEqualsB() {
        given()
            .when().get("/api/remainder/7/7")
            .then().statusCode(200)
            .body("resultAsInt", is(0));
    }

    // SCENARIO op=remainderUsingGET type=boundary expect=200
    @Test
    void remainderUsingGET_B_aZero() {
        given()
            .when().get("/api/remainder/0/5")
            .then().statusCode(200)
            .body("resultAsInt", is(0));
    }

    // SCENARIO op=remainderUsingGET type=boundary expect=error-class
    @Test
    void remainderUsingGET_B_bZero() {
        given()
            .when().get("/api/remainder/10/0")
            .then().statusCode(anyOf(is(200), is(400), is(422), is(500)));
    }

    // SCENARIO op=remainderUsingGET type=boundary expect=200
    @Test
    void remainderUsingGET_B_negativeA() {
        given()
            .when().get("/api/remainder/-7/3")
            .then().statusCode(anyOf(is(200), is(400), is(422)));
    }

    // SCENARIO op=remainderUsingGET type=boundary expect=200
    @Test
    void remainderUsingGET_B_negativeB() {
        given()
            .when().get("/api/remainder/7/-3")
            .then().statusCode(anyOf(is(200), is(400), is(422)));
    }

    // SCENARIO op=remainderUsingGET type=negative expect=error-class
    @Test
    void remainderUsingGET_N_aIsFloat() {
        given()
            .when().get("/api/remainder/3.5/2")
            .then().statusCode(anyOf(is(400), is(404), is(422), is(500)));
    }

    // SCENARIO op=remainderUsingGET type=negative expect=error-class
    @Test
    void remainderUsingGET_N_aIsString() {
        given()
            .when().get("/api/remainder/abc/3")
            .then().statusCode(anyOf(is(400), is(404), is(422), is(500)));
    }

    // SCENARIO op=remainderUsingGET type=errorcode expect=error-class
